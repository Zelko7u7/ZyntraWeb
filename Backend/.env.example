# Copia este archivo como `.env` (mismo directorio Backend/) y rellena los valores.
# NO subas el .env real al repositorio.

# === Django ===
# Genera uno nuevo en prod con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-replace-me-in-production
DEBUG=True
# Hosts permitidos separados por coma (ej: midominio.com,api.midominio.com).
# Déjalo vacío en dev para usar el default (localhost, 127.0.0.1).
ALLOWED_HOSTS=

# === Base de datos PostgreSQL ===
DB_NAME=fitness_db
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_HOST=localhost
DB_PORT=5432
